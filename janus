#!/usr/bin/env bash
####################################################################
## janus-cli
## @author:   Matt Gleeson
## @version:  1.0.0
## @build:    20260514
## @description:
##  CLI tool to perform recursive literal find/replace on strings in
##  filenames, directory names, and text file contents.
##
## Usage:
##  janus-cli OLD NEW [ROOT]
##
## Examples:
##  DRYRUN=1 janus-cli old.example.com new.example.com /var/www
##  janus-cli old.example.com new.example.com /etc/apache2/sites-available
##  RENAME_ROOT=1 janus-cli old.example.com new.example.com /var/www/old.example.com
##
## Environment options:
##  DRYRUN=1       Preview changes without modifying anything.
##  RENAME_ROOT=1  Allow the root directory itself to be renamed.
####################################################################
set -euo pipefail

old="${1:-}"
new="${2:-}"
root="${3:-.}"

dryrun="${DRYRUN:-0}"
rename_root="${RENAME_ROOT:-0}"

if [[ -z "$old" ]]; then
    echo "Error: old string must not be empty" >&2
    echo "Usage: $0 OLD NEW [ROOT]" >&2
    echo "Example: $0 oldtext newtext ." >&2
    echo
    echo "Optional:"
    echo "  DRYRUN=1       Preview changes without modifying anything"
    echo "  RENAME_ROOT=1  Allow the root directory itself to be renamed"
    exit 1
fi

if [[ ! -d "$root" ]]; then
    echo "Error: root path is not a directory: $root" >&2
    exit 1
fi

if ! command -v perl >/dev/null 2>&1; then
    echo "Error: perl is required for safe in-file replacement" >&2
    exit 1
fi

# Resolve root to an absolute path so comparisons are reliable.
root="$(cd "$root" && pwd -P)"

export OLD="$old"
export NEW="$new"

echo "Root: $root"
echo "Replacing content: '$old' -> '$new'"
echo "Renaming files and directories containing: '$old'"
echo

###################################################
## 1. Replace text inside regular text files.
###################################################

while IFS= read -r -d '' file; do
    # grep -I skips binary files.
    # grep -F treats the search string literally, not as a regex.
    if grep -IqF -- "$old" "$file"; then
        if [[ "$dryrun" == "1" ]]; then
            echo "[DRY RUN] Would update content: $file"
        else
            echo "Updating content: $file"
            perl -pi -e 's/\Q$ENV{OLD}\E/$ENV{NEW}/g' "$file"
        fi
    fi
done < <(find "$root" -type f -print0)

echo

###################################################
##  2. Rename files and directories.
##
##    -depth is important:
##    it renames children before their parent directories.
###################################################

while IFS= read -r -d '' path; do
    # By default, do not rename the root directory itself.
    if [[ "$path" == "$root" && "$rename_root" != "1" ]]; then
        continue
    fi

    dir="$(dirname -- "$path")"
    base="$(basename -- "$path")"

    # Only rename items whose own basename contains the old string.
    if [[ "$base" != *"$old"* ]]; then
        continue
    fi

    newbase="${base//"$old"/$new}"
    target="$dir/$newbase"

    if [[ "$path" == "$target" ]]; then
        continue
    fi

    if [[ -e "$target" ]]; then
        echo "Skipping rename because target already exists:"
        echo "  Source: $path"
        echo "  Target: $target"
        continue
    fi

    if [[ "$dryrun" == "1" ]]; then
        echo "[DRY RUN] Would rename: $path -> $target"
    else
        echo "Renaming: $path -> $target"
        mv -- "$path" "$target"
    fi
done < <(find "$root" -depth \( -type f -o -type d \) -print0)
